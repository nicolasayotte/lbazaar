APP_NAME=Laravel
APP_ENV=local
APP_KEY=base64:aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa=
APP_DEBUG=true
APP_URL=http://lbazaar.test:9200
APP_PORT=9200
APP_SERVICE=app
APP_TIMEZONE=Asia/Tokyo
CORS_ALLOWED_ORIGINS=http://lbazaar.test:9200,http://localhost:3000

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=learning_bazaar
DB_USERNAME=sail
DB_PASSWORD=password

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120
SANCTUM_EXPIRATION_MINUTES=480

MEMCACHED_HOST=memcached

REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=aaaaaaaaaaaaaa
MAIL_PASSWORD=aaaaaaaaaaaaaa
MAIL_ENCRYPTION=tls
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=AAAAAAAAAAAAAAAAAAAA
AWS_SECRET_ACCESS_KEY=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA
AWS_DEFAULT_REGION=ap-northeast-1
AWS_BUCKET=production-lebazaar
AWS_STAGING_BUCKET=staging-lebazaar
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

API_EXCHANGE_POINTS_TO_NFT_URL=

DISCORD_WEBOOK_URL=https://discord.com/api/webhooks/1111111111111111111/aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa-AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA

BLOCKFROST_API_KEY="blockfrost.io key goes here"
FEED_WEBHOOK_AUTH_TOKEN="get webhook auth token from blockfrost"
EXCHANGE_WEBHOOK_AUTH_TOKEN="get webhook auth token from blockfrost"
OWNER_WALLET_ADDR="wallet address for revenue"
OWNER_PKH="owner pkh goes here"
ROOT_KEY="owner root key goes here"

OPTIMIZE=true
NETWORK=preprod
CARDANO_EXPLORER_URL=https://preprod.cardanoscan.io
MIN_ADA=2000000
MAX_TX_FEE=500000
MIN_CHANGE_AMT=1000000
CERTIFICATE_LOCK_DATE=2027-12-31T23:59:59Z

# Minutes before an unconfirmed ADA payment is marked failed (see OQ-03)
ADA_PAYMENT_TIMEOUT_MINUTES=
PAYMENT_QUOTE_WINDOW_MINUTES=5
CARDANO_NETWORK_ID=0

# Exchange Rate API
COINGECKO_API_URL=https://api.coingecko.com/api/v3
EXCHANGE_RATE_CACHE_TTL=600
EXCHANGE_RATE_FALLBACK_CACHE_TTL=60
# Fallback rate used by ExchangeRateSettingSeeder (update regularly to match market rates)
EXCHANGE_RATE_FALLBACK=50

# Stripe Payment Integration (Credit Card Payments)
# Get keys from: https://dashboard.stripe.com/apikeys
# Test mode: pk_test_xxx / sk_test_xxx | Live mode: pk_live_xxx / sk_live_xxx
STRIPE_KEY=pk_test_xxx
STRIPE_SECRET=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
VITE_STRIPE_PUBLIC_KEY="${STRIPE_KEY}"

{
    "private": true,
    "scripts": {
        "dev": "vite",
        "build": "vite build",
        "test": "vitest run --reporter=verbose > docs/test-reports/js-unit-tests.log 2>&1",
        "test:watch": "vitest --watch",
        "test:coverage": "vitest --coverage",
        "test:postman": "newman run postman/lbazaar.postman_collection.json -e postman/local.postman_environment.json > docs/test-reports/postman-tests.log 2>&1",
        "test:web3": "cd web3 && npm test",
        "test:browser": "npx playwright test --reporter=list > docs/test-reports/playwright-tests.log 2>&1",
        "test:browser:ui": "npx playwright test --ui",
        "test:browser:headed": "npx playwright test --headed",
        "test:all": "npm run test && npm run test:web3 && npm run test:postman && npm run test:browser",
        "test:postman:staging": "newman run postman/lbazaar.postman_collection.json -e postman/staging.postman_environment.json",
        "test:integration": "npm run test:postman:staging; cd web3 && npm run test:integration; echo 'Run sail composer test:integration for PHP'"
    },
    "devDependencies": {
        "@playwright/test": "^1.58.2",
        "@testing-library/dom": "^10.4.1",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@testing-library/user-event": "^14.6.1",
        "happy-dom": "^20.6.1",
        "jsdom": "^28.1.0",
        "laravel-vite-plugin": "^0.6.0",
        "lodash": "^4.17.19",
        "postcss": "^8.1.14",
        "sass": "^1.55.0",
        "vite": "^3.0.0",
        "newman": "^6.2.1",
        "vitest": "^0.34.6"
    },
    "dependencies": {
        "@date-io/moment": "^2.16.1",
        "@emotion/react": "^11.10.5",
        "@emotion/styled": "^11.10.5",
        "@fontsource/roboto": "^4.5.8",
        "@inertiajs/inertia": "^0.11.1",
        "@inertiajs/inertia-react": "^0.8.1",
        "@inertiajs/progress": "^0.2.7",
        "@mui/icons-material": "^5.10.9",
        "@mui/lab": "^5.0.0-alpha.124",
        "@mui/material": "^5.10.12",
        "@mui/x-date-pickers": "^5.0.10",
        "@reduxjs/toolkit": "^1.9.1",
        "@stripe/react-stripe-js": "^5.6.0",
        "@stripe/stripe-js": "^8.7.0",
        "@vitejs/plugin-react": "^2.2.0",
        "axios": "^1.6.2",
        "bootstrap": "^5.2.2",
        "dayjs": "^1.11.7",
        "moment": "^2.29.4",
        "mui-file-input": "^1.1.3",
        "react": "^18.2.0",
        "react-device-detect": "^2.2.3",
        "react-dom": "^18.2.0",
        "react-quill": "^2.0.0",
        "react-redux": "^8.0.5",
        "redux": "^4.2.0"
    }
}

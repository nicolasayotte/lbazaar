              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('returns 200', function () { pm.response.to.have.status(200); });",
                  "var json = pm.response.json();",
                  "pm.test('response has success field', function () { pm.expect(json.success).to.be.true; });",
                  "pm.test('response has data field with students array', function () { pm.expect(json.data).to.be.an('object'); pm.expect(json.data.students).to.be.an('array'); });",
                  "pm.test('students array contains required fields', function () { if (json.data.students.length > 0) { pm.expect(json.data.students[0]).to.have.property('id'); pm.expect(json.data.students[0]).to.have.property('name'); pm.expect(json.data.students[0]).to.have.property('email'); pm.expect(json.data.students[0]).to.have.property('certificate_status'); } });",
                  "if (json.data.students && json.data.students.length > 0) { pm.environment.set('eligible_student_id', json.data.students[0].id); }"
                ]
              }
            }
          ]
